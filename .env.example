# LLM Provider API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-api-key

# Optional: Custom model configuration
# INQUIRO_DEFAULT_MODEL=claude-sonnet-4-5
# INQUIRO_ANALYSIS_MODELS=claude-sonnet-4-5,gpt-5-2,gemini-3-pro

# Optional: Cost budget per evaluation (USD)
# INQUIRO_COST_BUDGET=20.0

# Optional: Server configuration
# INQUIRO_HOST=0.0.0.0
# INQUIRO_PORT=8000
